# =====================================================
#  Production environment template
# =====================================================
#  ⚠️  NEVER commit the real .env.production to git!
#  本文件只是模板，给运维参考。真实密钥在服务器上手动生成。
#
#  生成强密钥:
#    MYSQL_PASSWORD=$(openssl rand -base64 18 | tr -d "/+= " | head -c 20)
#    JWT_SECRET=$(openssl rand -hex 32)
# =====================================================

NODE_ENV=production

# --- MySQL (容器内叫 "mysql"，docker compose 会解析) ---
MYSQL_ROOT_PASSWORD=<run: openssl rand -base64 18 | tr -d "/+= " | head -c 20>
MYSQL_USER=barcode_app
MYSQL_PASSWORD=<run: openssl rand -base64 18 | tr -d "/+= " | head -c 20>
MYSQL_DATABASE=barcode_checker

# --- App 用的 DATABASE_URL（注意：host 是 docker 内部网络名 "mysql"，不是 localhost）---
DATABASE_URL=mysql://barcode_app:${MYSQL_PASSWORD}@mysql:3306/barcode_checker

# --- JWT session secret（30+ 字符的随机串）---
JWT_SECRET=<run: openssl rand -hex 32>

# --- 端口（容器内监听 3000，由 nginx 反代到 /barcode/）---
PORT=3000
